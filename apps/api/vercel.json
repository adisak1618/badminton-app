{
  "framework": null,
  "buildCommand": "cd ../.. && turbo run build --filter=api",
  "outputDirectory": ".",
  "installCommand": "cd ../.. && pnpm install",
  "functions": {
    "api/index.js": {
      "runtime": "bun@1.0.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}