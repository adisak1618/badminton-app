{
  "name": "badminton",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "set -a && source .env.local && set +a && bun test",
    "test:db": "set -a && source .env.local && set +a && pnpm --filter @repo/db test",
    "test:api": "set -a && source .env.local && set +a && pnpm --filter api test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.9.0"
  }
}
